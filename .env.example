# Required
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
QDRANT_URL=https://xxxxxxxx.us-east-1-0.aws.cloud.qdrant.io
QDRANT_API_KEY=xxxxxxxxxxxxxxxxxxxx

# Optional — omit to use local BAAI/bge-m3 for dense embeddings
VOYAGE_API_KEY=pa-xxxxxxxxxxxxxxxxxxxxxx

# Optional — provides 5,000 req/hr vs 60/hr unauthenticated for issue fetching
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Optional overrides (defaults shown)
GROQ_MODEL=llama-3.1-70b-versatile
QDRANT_COLLECTION=codebase_rag
